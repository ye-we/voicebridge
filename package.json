{
  "name": "@yewe/voicebridge",
  "version": "0.2.0",
  "description": "One SDK for voice AI agents. Switch between Vapi, Retell and more — no vendor lock-in.",
  "license": "MIT",
  "author": "Yewe <khalid.yewe@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ye-we/voicebridge.git"
  },
  "homepage": "https://github.com/ye-we/voicebridge#readme",
  "bugs": "https://github.com/ye-we/voicebridge/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "voice-ai",
    "vapi",
    "retell",
    "voice-agents",
    "sdk",
    "typescript",
    "ai-agents",
    "telephony"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
